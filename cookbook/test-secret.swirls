secret test_creds {
  vars: [SLACK_WEBHOOK_URL]
}

webhook test_hook {
  label: "Test"
  schema: @json {
    { "type": "object", "properties": { "x": { "type": "string" } } }
  }
}

graph test_secret {
  label: "Test Secret"
  root {
    type: code
    label: "Read secret"
    code: @ts {
      var keys = context.secrets.test_creds ? Object.keys(context.secrets.test_creds) : []
      var val = context.secrets.test_creds ? String(context.secrets.test_creds.SLACK_WEBHOOK_URL) : "missing block"
      return {
        keys: keys,
        val: val
      }
    }
    secrets: {
      test_creds: [SLACK_WEBHOOK_URL]
    }
  }
}

trigger t {
  webhook:test_hook -> test_secret
  enabled: true
}
